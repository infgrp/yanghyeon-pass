# Supabase 프로젝트 설정 (Settings > API 에서 복사)
# 이 파일을 .env 로 복사한 뒤 값을 채우세요.
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
# 웹 푸시 VAPID 공개키 (npx web-push generate-vapid-keys 로 생성)
VITE_VAPID_PUBLIC_KEY=B...
# (선택) QR 검증 링크 기준 도메인. 미설정 시 코드 기본값(실서비스 도메인) 사용
# VITE_PUBLIC_BASE_URL=https://yanghyeon-pass.vercel.app
